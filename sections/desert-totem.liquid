{%- comment -%}
  Kazan Studio — Desert Totem Project Page
  Portfolio piece, not for sale. Commission via email.
{%- endcomment -%}

<style>
  .dt-hero {
    width: 100%;
    height: 85vh;
    overflow: hidden;
    background: var(--charcoal);
  }
  .dt-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .dt-intro__grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 80px;
    align-items: start;
  }
  .dt-intro h1 {
    margin-bottom: 2rem;
  }
  .dt-intro__body p {
    font-size: 1.125rem;
    font-weight: 200;
    line-height: 2;
    margin-bottom: 1.25em;
  }
  .dt-intro__body p:last-child { margin-bottom: 0; }

  .dt-specs {
    border-top: 1px solid var(--sand);
    padding-top: 2rem;
  }
  .dt-spec {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--sand);
  }
  .dt-spec__label {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--accent);
  }
  .dt-spec__value {
    font-weight: 300;
    font-size: 0.9375rem;
    color: var(--charcoal);
    text-align: right;
  }

  .dt-gallery__grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 16px;
  }
  .dt-gallery__item {
    overflow: hidden;
    background: var(--sand);
  }
  .dt-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .dt-gallery__item--tall {
    grid-row: 1 / 3;
  }
  .dt-gallery__item--tall img {
    aspect-ratio: 3 / 4;
    height: 100%;
  }
  .dt-gallery__item--square img {
    aspect-ratio: 1 / 1;
  }
  .dt-gallery__item--landscape img {
    aspect-ratio: 4 / 3;
  }
  .dt-gallery__item--full {
    grid-column: 1 / 3;
  }
  .dt-gallery__item--full img {
    aspect-ratio: 16 / 7;
  }

  .dt-process__header {
    margin-bottom: 3rem;
  }
  .dt-process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }
  .dt-video {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .dt-video video {
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    background: var(--sand);
    display: block;
  }
  .dt-video__label {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--charcoal);
  }

  .dt-commission {
    background: var(--charcoal);
    text-align: center;
  }
  .dt-commission .eyebrow { color: var(--clay); }
  .dt-commission h2 {
    color: var(--warm-white);
    margin-bottom: 1.5rem;
  }
  .dt-commission__body {
    font-size: 1.125rem;
    font-weight: 200;
    line-height: 2;
    color: var(--sand);
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }
  .dt-commission .btn--primary {
    background: var(--warm-white);
    color: var(--charcoal);
  }
  .dt-commission .btn--primary:hover {
    background: var(--clay);
    color: var(--warm-white);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .dt-intro__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .dt-process__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .dt-video video {
      aspect-ratio: 16 / 9;
    }
    .dt-gallery__grid {
      grid-template-columns: 1fr 1fr;
    }
    .dt-gallery__item--tall {
      grid-row: auto;
    }
    .dt-gallery__item--tall img {
      aspect-ratio: 3 / 4;
      height: auto;
    }
  }
  @media (max-width: 600px) {
    .dt-hero { height: 60vh; }
    .dt-gallery__grid {
      grid-template-columns: 1fr;
    }
    .dt-gallery__item--full {
      grid-column: 1;
    }
    .dt-gallery__item--full img {
      aspect-ratio: 4 / 3;
    }
  }
</style>

{%- comment -%} Hero {%- endcomment -%}
{%- if section.settings.img_hero != blank -%}
  <div class="dt-hero">
    <img
      src="{{ section.settings.img_hero }}"
      alt="Desert Totem — Mojave desert installation"
      loading="eager"
    >
  </div>
{%- endif -%}

{%- comment -%} Intro {%- endcomment -%}
<section class="section-padding dt-intro">
  <div class="page-width">
    <div class="dt-intro__grid">

      <div class="dt-intro__copy">
        <p class="eyebrow">2025 — Stoneware</p>
        <h1>Desert Totem</h1>
        <div class="dt-intro__body">
          <p>Fired stoneware holds time differently than almost any other material. Civilizations disappear. Languages go silent. But the pottery stays — dug out of desert floors thousands of years later, still legible, still whole.</p>
          <p>Desert Totem was built with that in mind. The forms are stacked, modular, deliberately incomplete-feeling — as if they were found rather than made. The surfaces are carved and glazed to read like something uncovered, not finished. Like it had already survived.</p>
          <p>The work asks a simple question: if this piece were buried today and pulled from the ground in three thousand years, what would it say about what was made here?</p>
        </div>
      </div>

      <div class="dt-specs">
        <div class="dt-spec">
          <span class="dt-spec__label">Year</span>
          <span class="dt-spec__value">2025</span>
        </div>
        <div class="dt-spec">
          <span class="dt-spec__label">Material</span>
          <span class="dt-spec__value">Stoneware</span>
        </div>
        <div class="dt-spec">
          <span class="dt-spec__label">Technique</span>
          <span class="dt-spec__value">Hand-built, carved</span>
        </div>
        <div class="dt-spec">
          <span class="dt-spec__label">Edition</span>
          <span class="dt-spec__value">One of a kind</span>
        </div>
        <div class="dt-spec">
          <span class="dt-spec__label">Status</span>
          <span class="dt-spec__value">Not for sale</span>
        </div>
      </div>

    </div>
  </div>
</section>

{%- comment -%} Gallery {%- endcomment -%}
{%- assign has_gallery = false -%}
{%- if section.settings.img_1 != blank or section.settings.img_2 != blank or section.settings.img_3 != blank or section.settings.img_4 != blank -%}
  {%- assign has_gallery = true -%}
{%- endif -%}

{%- if has_gallery -%}
<section style="padding-bottom: 120px;">
  <div class="page-width">
    <div class="dt-gallery__grid">
      {%- if section.settings.img_1 != blank -%}
        <div class="dt-gallery__item dt-gallery__item--tall">
          <img src="{{ section.settings.img_1 }}" alt="Desert Totem — glaze detail" loading="lazy">
        </div>
      {%- endif -%}
      {%- if section.settings.img_2 != blank -%}
        <div class="dt-gallery__item dt-gallery__item--square">
          <img src="{{ section.settings.img_2 }}" alt="Desert Totem" loading="lazy">
        </div>
      {%- endif -%}
      {%- if section.settings.img_3 != blank -%}
        <div class="dt-gallery__item dt-gallery__item--landscape">
          <img src="{{ section.settings.img_3 }}" alt="Desert Totem — installation" loading="lazy">
        </div>
      {%- endif -%}
      {%- if section.settings.img_4 != blank -%}
        <div class="dt-gallery__item dt-gallery__item--full">
          <img src="{{ section.settings.img_4 }}" alt="Desert Totem" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%} Process videos {%- endcomment -%}
{%- assign has_videos = false -%}
{%- if section.settings.video_process != blank or section.settings.video_glaze != blank or section.settings.video_installation != blank -%}
  {%- assign has_videos = true -%}
{%- endif -%}

{%- if has_videos -%}
<section class="section-padding dt-process">
  <div class="page-width">
    <div class="dt-process__header">
      <p class="eyebrow">Process</p>
    </div>
    <div class="dt-process__grid">
      {%- if section.settings.video_process != blank -%}
        <div class="dt-video">
          <video
            src="{{ section.settings.video_process }}"
            controls
            playsinline
            preload="none"
            aria-label="Hand-building process"
          ></video>
          <span class="dt-video__label">Hand-Building</span>
        </div>
      {%- endif -%}
      {%- if section.settings.video_glaze != blank -%}
        <div class="dt-video">
          <video
            src="{{ section.settings.video_glaze }}"
            controls
            playsinline
            preload="none"
            aria-label="Glazing in spray booth"
          ></video>
          <span class="dt-video__label">Glazing</span>
        </div>
      {%- endif -%}
      {%- if section.settings.video_installation != blank -%}
        <div class="dt-video">
          <video
            src="{{ section.settings.video_installation }}"
            controls
            playsinline
            preload="none"
            aria-label="Desert installation"
          ></video>
          <span class="dt-video__label">Installation</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%} Commission CTA {%- endcomment -%}
<section class="section-padding dt-commission">
  <div class="page-width">
    <p class="eyebrow">Commission</p>
    <h2>Interested in a commission?</h2>
    <p class="dt-commission__body">This piece is not for sale, but the form is open to commission. Each piece is built and glazed by hand — the same process, a different result. Get in touch to discuss what you have in mind.</p>
    <a
      href="mailto:info@kazan.studio?subject=Desert%20Totem%20Commission%20Inquiry"
      class="btn btn--primary"
    >Get in Touch</a>
  </div>
</section>

