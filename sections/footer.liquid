{%- comment -%}
  Kazan Studio — Footer Section
{%- endcomment -%}

<footer class="site-footer">
  <div class="page-width">
    <div class="site-footer__inner">
      <div class="site-footer__brand">
        <div style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 12px;">
          {%- render 'logo-mark', variant: 'light' -%}
          <span style="font-family: var(--font-heading); font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--sand);">KAZAN STUDIO</span>
        </div>
        <p>{{ section.settings.footer_text }}</p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <div class="site-footer__links">
                {%- for link in block.settings.menu.links -%}
                  <a href="{{ link.url }}">{{ link.title }}</a>
                {%- endfor -%}
              </div>
            </div>

          {%- when 'text' -%}
            <div class="site-footer__col" {{ block.shopify_attributes }}>
              <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
              <div class="site-footer__links">
                <p style="font-size: 0.875rem; font-weight: 300; color: var(--sand); opacity: 0.7; line-height: 1.8;">
                  {{ block.settings.text }}
                </p>
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </span>
      <div style="display: flex; gap: 24px;">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" style="color: var(--sand); opacity: 0.5;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Brand description",
      "default": "Precision meets unpredictability in clay. Geometric ceramics & sculptural totems. Los Angeles."
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Navigate"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Studio"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Los Angeles, CA</p>"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Navigate",
          "menu": "footer"
        }
      },
      {
        "type": "text",
        "settings": {
          "heading": "Studio",
          "text": "<p>Los Angeles, CA</p>"
        }
      }
    ]
  }
}
{% endschema %}
