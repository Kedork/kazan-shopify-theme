{%- comment -%}
  Kazan Studio — Hero Banner
  Full-viewport hero with image/video background
{%- endcomment -%}

<section class="hero" data-hero>
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
      >
    {%- endif -%}
  </div>

  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1>{{ section.settings.heading | default: shop.name }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (overrides image)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Los Angeles"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kazan Studio"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Precision meets unpredictability in clay."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Work"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
