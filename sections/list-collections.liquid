{%- comment -%}
  Kazan Studio — Collections Index
  Order and visibility controlled by the "collections-menu" link list in Shopify admin.
  Drag to reorder: Online Store → Navigation → Collections menu
{%- endcomment -%}

<div class="collections-index">
  <div class="collections-index__header page-width">
    <p class="eyebrow">Work</p>
    <h1>Collections</h1>
  </div>

  <div class="collections-index__bands">
    {%- for link in linklists['collections-menu'].links -%}
      {%- assign collection = link.object -%}
      <a href="{{ collection.url }}" class="collection-card">
        <div class="collection-card__image">
          {%- if collection.image != blank -%}
            <img
              src="{{ collection.image | image_url: width: 1400 }}"
              alt="{{ collection.title | escape }}"
              loading="lazy"
            >
          {%- elsif collection.products.first.featured_image != blank -%}
            <img
              src="{{ collection.products.first.featured_image | image_url: width: 1400 }}"
              alt="{{ collection.title | escape }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="collection-card__overlay">
          <p class="collection-card__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'piece', 'pieces' }}</p>
          <h2 class="collection-card__title">{{ collection.title }}</h2>
          {%- if collection.description != blank -%}
            <div class="collection-card__description">{{ collection.description }}</div>
          {%- endif -%}
          <span class="collection-card__cta">View Collection</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collections index",
  "presets": [
    {
      "name": "Collections index"
    }
  ]
}
{% endschema %}
