{%- comment -%}
  Kazan Studio — Main Collection Section
  Used as the primary section on collection.json template
{%- endcomment -%}

<section class="collection-page section-padding">
  <div class="page-width">
    <div class="collection-page__header">
      <p class="eyebrow">Work</p>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p>{{ collection.description }}</p>
      {%- endif -%}
    </div>

    {%- if collection.products.size > 0 -%}
      <div class="collection-page__filter">
        <span class="collection-page__count">
          {{ collection.products_count }} {{ collection.products_count | pluralize: 'piece', 'pieces' }}
        </span>
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <select class="collection-page__sort" data-sort-select>
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </div>

      <div class="grid grid--{{ section.settings.columns }}">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="text-center mt-2">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="text-center">
        <p class="body-large">No pieces in this collection yet.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary mt-2">View All Work</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "Grid columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ]
}
{% endschema %}
